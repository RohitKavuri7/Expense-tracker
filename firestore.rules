rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isValidCategory(category) {
      return category in ['Food', 'Transport', 'Utilities', 'Entertainment', 'Other'];
    }
    function isValidExpensePayload(data) {
      return data.uid is string
        && isOwner(data.uid)
        && data.name is string
        && data.amount is number
        && data.amount > 0
        && isValidCategory(data.category)
        && data.date is string
        && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.dateEpoch is number
        && data.dateEpoch > 946684800000 // >= 2000-01-01
        && data.dateEpoch <= request.time.toMillis() + 86400000 // not unrealistic future
        && (!('sharedWith' in data) || data.sharedWith is list)
        && (!('receiptURL' in data) || data.receiptURL is string);
    }

    // Expenses: user can only read/write their own (uid field must match auth.uid)
    match /expenses/{expenseId} {
      allow create: if isValidExpensePayload(request.resource.data);
      allow read, delete: if isOwner(resource.data.uid);
      allow update: if isOwner(resource.data.uid)
        && request.resource.data.uid == resource.data.uid
        && isValidExpensePayload(request.resource.data);
    }

    // Budgets: doc id is user.uid
    match /budgets/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.data.budget is number
        && request.resource.data.budget > 0;
    }

    // Users: doc id is user.uid (profile data)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      // Profiles subcollection: only the owner
      match /profiles/{profileId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Derived monthly stats for analytics acceleration
    match /userMonthlyStats/{docId} {
      allow read: if isOwner(resource.data.uid);
      allow create, update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(resource.data.uid);
    }

    // Agent observability logs
    match /agentLogs/{logId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.latencyMs is number
        && request.resource.data.fallbackUsed is bool;
      allow read: if isOwner(resource.data.uid);
      allow update, delete: if false;
    }
  }
}
